# ============================================================
#  SaaS Opportunity Hunter Bot — .env.example
#  Copy to .env and fill in your keys. Never commit .env.
# ============================================================

# --- Scraping Engine (pick one) ---
SCRAPING_ENGINE=scrapingbee        # scrapingbee | apify | requests

SCRAPINGBEE_API_KEY=               # https://app.scrapingbee.com
APIFY_API_KEY=                     # https://console.apify.com/account/integrations

# --- LLM Provider (pick one) ---
LLM_PROVIDER=anthropic             # anthropic | openai

ANTHROPIC_API_KEY=                 # https://console.anthropic.com
OPENAI_API_KEY=                    # https://platform.openai.com/api-keys

# --- Optional: Airtable Output ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=                  # e.g. appXXXXXXXXXXXXXX
AIRTABLE_TABLE=FeatureGaps

# --- Optional: Supabase (future vector search) ---
SUPABASE_URL=
SUPABASE_KEY=
